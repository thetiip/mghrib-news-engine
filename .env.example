# Database
DATABASE_URL=sqlite:///./news.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Scraping Configuration
SCRAPING_INTERVAL=3600  # in seconds (1 hour)
MAX_ARTICLES_PER_SOURCE=50

# Sentiment Analysis
SENTIMENT_MODEL=CAMeL-Lab/bert-base-arabic-camelbert-msa-sentiment
USE_GPU=false

# Logging
LOG_LEVEL=INFO
